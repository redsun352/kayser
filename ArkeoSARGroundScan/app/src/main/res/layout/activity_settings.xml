<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_deep"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textColor="@color/signal_amber"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_area_meters"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/seekArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="25"
        android:min="1"
        android:progress="5" />

    <TextView
        android:id="@+id/areaValueText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchAutoMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_auto_mode"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchZigzag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_zigzag"
        android:textColor="@color/text_primary"
        android:checked="true"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_source_info"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnSaveSettings"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_save" />

</LinearLayout>
